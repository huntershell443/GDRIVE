# ===== Django =====
SECRET_KEY=troque-por-uma-chave-secreta-forte
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# ===== E-mail (SMTP) =====
EMAIL_HOST_USER=seu-email@exemplo.com
EMAIL_HOST_PASSWORD=sua-senha-de-app

# ===== Armazenamento de mídia =====
MEDIA_ROOT=D:/GDrive_users/

# ===== Ollama =====
OLLAMA_DEFAULT_MODEL=CORE-rupto
OLLAMA_SYSTEM_PROMPT=
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=2048
# Acessado do container Django via host
OLLAMA_API_URL=http://host.docker.internal:11434/api/generate

# ===== APIs externas =====
VT_API_KEY=sua-chave-virustotal

# ===== PostgreSQL (usado quando DEBUG=False) =====
POSTGRES_DB=gdrive
POSTGRES_USER=gdrive
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60
